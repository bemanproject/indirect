#ifndef BEMAN_INDIRECT_DETAIL_CONFIG_HPP
#define BEMAN_INDIRECT_DETAIL_CONFIG_HPP

// ---------------------------------------------------------------------------
// Feature flags (generated by CMake — do not edit)
// ---------------------------------------------------------------------------

#cmakedefine01 BEMAN_INDIRECT_USE_CONCEPTS
#cmakedefine01 BEMAN_INDIRECT_USE_THREE_WAY_COMPARISON
#cmakedefine01 BEMAN_INDIRECT_USE_CONSTEXPR_DESTRUCTOR
#cmakedefine01 BEMAN_INDIRECT_USE_CONSTEXPR_VIRTUAL
#cmakedefine01 BEMAN_INDIRECT_USE_CONSTEXPR_POLYMORPHIC_EVAL
#cmakedefine01 BEMAN_INDIRECT_USE_NO_UNIQUE_ADDRESS

// ---------------------------------------------------------------------------
// Derived macros
// ---------------------------------------------------------------------------

#if BEMAN_INDIRECT_USE_CONSTEXPR_DESTRUCTOR
#define BEMAN_INDIRECT_CONSTEXPR_DTOR constexpr
#else
#define BEMAN_INDIRECT_CONSTEXPR_DTOR
#endif

#if BEMAN_INDIRECT_USE_CONSTEXPR_VIRTUAL
#define BEMAN_INDIRECT_CONSTEXPR_VIRTUAL constexpr
#else
#define BEMAN_INDIRECT_CONSTEXPR_VIRTUAL
#endif

#if BEMAN_INDIRECT_USE_NO_UNIQUE_ADDRESS
#define BEMAN_INDIRECT_NO_UNIQUE_ADDRESS [[no_unique_address]]
#else
#define BEMAN_INDIRECT_NO_UNIQUE_ADDRESS
#endif

// ---------------------------------------------------------------------------
// Polyfills
// ---------------------------------------------------------------------------

#include <memory>
#include <new>
#include <type_traits>

#if BEMAN_INDIRECT_USE_CONCEPTS
#include <concepts>
#endif

#if BEMAN_INDIRECT_USE_THREE_WAY_COMPARISON
#include <compare>
#endif

namespace beman::indirect::detail {

// remove_cvref_t (always our own — trivial, avoids version branching)
template <class T>
using remove_cvref_t = std::remove_cv_t<std::remove_reference_t<T>>;

// construct_at polyfill
#if BEMAN_INDIRECT_USE_CONCEPTS
// Use std::construct_at when we have C++20 (concepts implies C++20)
template <class T, class... Args>
constexpr T* construct_at_impl(T* p, Args&&... args) {
    return std::construct_at(p, std::forward<Args>(args)...);
}
#else
template <class T, class... Args>
T* construct_at_impl(T* p, Args&&... args) {
    return ::new (static_cast<void*>(p)) T(std::forward<Args>(args)...);
}
#endif

// to_address polyfill
template <class T>
constexpr T* to_address_impl(T* p) noexcept {
    return p;
}

#if BEMAN_INDIRECT_USE_CONCEPTS
// std::to_address is available in C++20
template <class Ptr, std::enable_if_t<!std::is_pointer_v<Ptr>, int> = 0>
constexpr auto to_address_impl(const Ptr& p) noexcept {
    return std::to_address(p);
}
#endif

// derived_from polyfill
template <class Derived, class Base>
inline constexpr bool derived_from_v =
#if BEMAN_INDIRECT_USE_CONCEPTS
    std::derived_from<Derived, Base>;
#else
    std::is_base_of_v<Base, Derived> && std::is_convertible_v<const volatile Derived*, const volatile Base*>;
#endif

} // namespace beman::indirect::detail

#endif // BEMAN_INDIRECT_DETAIL_CONFIG_HPP
